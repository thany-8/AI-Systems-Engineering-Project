# Copy this file to .env and fill in your key to enable Gemini reasoning.
# Without a key the app still runs fully in deterministic "offline" mode.
#
# Get a free API key from Google AI Studio: https://aistudio.google.com/app/apikey

GEMINI_API_KEY=

# Secret used to sign login-session cookies. Set any long random string in
# production (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`).
SECRET_KEY=

# Optional overrides
GEMINI_MODEL=gemini-1.5-flash
# DATABASE_URL=sqlite:///app/app.sqlite
# PORT=5000
